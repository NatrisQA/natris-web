  <script>
    // 폴드 외부 스크린 등 375px 미만 기기: viewport를 375px로 고정
    // → 브라우저가 균일 축소 렌더링하여 fixed/absolute 좌표계 불일치 방지
    !function(){try{var w=Math.min(screen.width,screen.height);if(w>0&&w<375)document.querySelector('meta[name="viewport"]').setAttribute('content','width=375, maximum-scale=1.0, viewport-fit=cover')}catch(e){}}();
  </script>
